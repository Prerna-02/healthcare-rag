# Environment
.env
.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store

# Data — never commit PDFs or vector store to git.
# Ignore the *contents* of docs/ (not the folder itself) so we can re-include
# one file: git cannot un-ignore a file whose parent directory is ignored.
docs/*
chroma_db/
# ...but DO track the source metadata manifest (filenames + citation info, no PDF content)
!docs/sources.json

# Local editor / harness settings — never publish
.claude/

# Evaluation outputs
eval/results/

# Python packaging artifacts
*.egg-info/
dist/
build/

# Conda transient pip-requirements file (created during env create/update)
condaenv.*.requirements.txt

# Internal working docs — kept locally, not published to the public repo
healthcare_rag_roadmap.md
healthcare_rag_ethics_guardrails.md
